generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Catalog {
  id            String   @id @default(cuid())
  catalogNumber String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dresses       Dress[]
}

model Dress {
  id            String   @id @default(cuid())
  name          String
  stockMeters     Float    @default(0)
  pricePerMeter   Float    @default(0)
  totalMetersSold Float    @default(0)
  imageUrl        String?
  catalogId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  catalog       Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  orders        Order[]
  stockRequests StockRequest[]
}

model StockRequest {
  id            String   @id @default(cuid())
  customerName  String
  phoneNumber   String
  requestedMeters Float
  status        String   @default("PENDING") // PENDING, REVIEWED
  dressId       String
  createdAt     DateTime @default(now())

  dress         Dress    @relation(fields: [dressId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Order {
  id            String   @id @default(cuid())
  customerName  String
  phoneNumber   String
  address       String   @default("")
  paymentMode   String   @default("COD")
  mfsSenderNumber String?
  status        String   @default("PENDING")
  dressId       String
  orderedMeters Float
  totalPrice    Float    @default(0)
  createdAt     DateTime @default(now())

  dress         Dress    @relation(fields: [dressId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// NextAuth Models

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("CLIENT") // "ADMIN" or "CLIENT"
  orders        Order[]
  stockRequests StockRequest[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
